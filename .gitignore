# =====================================================================
# WYVERN REPOSITORY VERSION CONTROL OVERRIDES
# =====================================================================

# --- Python Core Bytecode & Runtime Caches ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# --- Local Application Output Assets & System Logs ---
# Keeps database error reports and generated web galleries restricted to your PC
wyvern_system_errors.log
wyvern_nft_gallery.html

# --- Virtual Environments & Local Environments ---
# Prevents thousands of local package dependencies from cluttering commits
.venv/
venv/
ENV/
env/
build/
dist/
*.egg-info/

# --- Operating System Footprints & IDE Overrides ---
# Filters out local editor metadata blocks and background cache files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.bak
